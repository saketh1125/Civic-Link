# Civic-Link DPI Environment Configuration
# Copy to .env and customize for your environment

# Application
DEBUG=true
ENVIRONMENT=development
SECRET_KEY=change-this-in-production-to-a-secure-random-string
API_V1_PREFIX=/api/v1
PROJECT_NAME=Civic-Link DPI

# Database
POSTGRES_USER=civic
POSTGRES_PASSWORD=civic_secret
POSTGRES_DB=civic_link
DATABASE_URL=postgresql+asyncpg://civic:civic_secret@localhost:5432/civic_link
POSTGIS_SRID=4326

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# Security
AUDIT_LOG_ENCRYPTION_KEY=generate-a-32-byte-key-for-aes-256-gcm
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Geospatial
DEFAULT_SEARCH_RADIUS=500
MAX_SEARCH_RADIUS=2000

# Cache
COMMUTE_CACHE_TTL=900
USER_CACHE_TTL=3600

# Telemetry
GYROSCOPE_THRESHOLD=1.5
SWERVE_COOLDOWN_MS=60000

# GDPR/RTI Compliance
ANONYMIZATION_DELAY_HOURS=24
