# Civic-Link DPI — Environment Configuration
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# Application
DEBUG=true
ENVIRONMENT=development
SECRET_KEY=change-me-in-production

# Database
POSTGRES_USER=civic
POSTGRES_PASSWORD=civic_secret
POSTGRES_DB=civic_link
DATABASE_URL=postgresql+asyncpg://civic:civic_secret@localhost:5432/civic_link

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# Security — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
AUDIT_LOG_ENCRYPTION_KEY=generate-a-32-byte-hex-key-for-aes-256-gcm
JWT_SECRET_KEY=generate-a-32-byte-hex-key-for-jwt-signing
ALGORITHM=HS256

# Token Expiry
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
